DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SCHEMA=chatbot
SUPABASE_DOCUMENTS_TABLE=documents
SUPABASE_CHAT_TABLE=chunks

TOUR_API_SERVICE_KEY=
TOUR_API_MOBILE_OS=ETC
TOUR_API_MOBILE_APP=Dadaeyu

# Optional. Used only when weather-sensitive chatbot questions need tourism climate data.
# If your data.go.kr account key is approved for the KMA tourism weather API,
# this can reuse the same encoded key as TOUR_API_SERVICE_KEY.
KMA_TOUR_WEATHER_SERVICE_KEY=
KMA_TOUR_WEATHER_CITY_AREA_ID=
KMA_TOUR_WEATHER_ENABLED=true

# Optional. Set this to enable OpenAI embedding + pgvector search.
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
